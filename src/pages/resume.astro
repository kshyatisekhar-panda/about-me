---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Kshyatisekhar Panda">
  <nav class="resume-nav">
    <div class="resume-nav-inner">
      <a href="/" class="nav-logo">KP<span class="accent">.</span></a>
      <div class="resume-actions">
        <a href="/resume.pdf" download class="btn btn-primary">Download PDF</a>
        <a href="/" class="btn btn-outline">Back to Portfolio</a>
      </div>
    </div>
  </nav>

  <main class="resume-viewer">
    <object data="/resume.pdf" type="application/pdf" class="resume-embed">
      <div class="resume-fallback">
        <p>Your browser doesn't support PDF previews.</p>
        <a href="/resume.pdf" download class="btn btn-primary">Download PDF instead</a>
      </div>
    </object>
  </main>
</BaseLayout>

<style>
  .resume-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 12px 0;
  }

  .resume-nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .resume-actions {
    display: flex;
    gap: 12px;
  }

  .resume-viewer {
    padding-top: 72px;
    height: 100vh;
    display: flex;
  }

  .resume-embed {
    width: 100%;
    flex: 1;
    border: none;
  }

  .resume-fallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    height: 100%;
    width: 100%;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  @media (max-width: 768px) {
    .resume-actions .btn {
      padding: 10px 16px;
      font-size: 0.85rem;
    }
  }
</style>
