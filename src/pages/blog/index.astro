---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog — Kshyatisekhar Panda" description="Writing about web development, AI, career growth, and life in Sweden.">
  <nav class="blog-nav">
    <div class="blog-nav-inner">
      <a href="/" class="nav-logo">KP<span class="accent">.</span></a>
      <a href="/" class="btn btn-outline btn-sm">Back to Portfolio</a>
    </div>
  </nav>

  <main class="blog-page">
    <div class="container">
      <h1 class="blog-heading">Blog</h1>
      <p class="blog-intro">
        Writing about things I've learned, built, and experienced as a developer.
      </p>

      <div class="posts-list">
        {posts.map((post) => (
          <a href={post.data.devtoUrl || `/blog/${post.id}`} target={post.data.devtoUrl ? '_blank' : '_self'} rel={post.data.devtoUrl ? 'noopener' : undefined} class="post-card">
            <div class="post-card-top">
              <div class="post-date">{new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</div>
              {post.data.devtoUrl && <span class="devto-badge">dev.to</span>}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .blog-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 12px 0;
  }

  .blog-nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .btn-sm {
    padding: 8px 18px;
    font-size: 0.85rem;
  }

  .blog-page {
    padding-top: 100px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .blog-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .blog-intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 48px;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-card {
    display: block;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px 32px;
    transition: var(--transition);
    text-decoration: none;
    color: inherit;
  }

  .post-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .devto-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #fff;
    background: #08090a;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .post-desc {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .post-tag {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }
</style>
