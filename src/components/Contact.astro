  {
    icon: '✉',
    label: 'Email',
    value: 'kshyatisekhar.dev@gmail.com',
    href: 'mailto:kshyatisekhar.dev@gmail.com',
  },
  {
    icon: 'in',
    label: 'LinkedIn',
    value: 'Kshyatisekhar Panda',
    href: 'https://www.linkedin.com/in/kshyatisekhar-panda-589973145/',
  },
  {
    icon: '💻',
    label: 'GitHub',
    value: 'kshyatisekhar-panda',
    href: 'https://github.com/kshyatisekhar-panda',
  },
  {
    icon: '▶',
    label: 'YouTube',
    value: '@imhumanpanda_',
    href: 'https://youtube.com/@imhumanpanda_',
  },
  {
    icon: '📸',
    label: 'Instagram (Sports)',
