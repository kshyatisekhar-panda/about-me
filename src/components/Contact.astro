---

<section class="section contact" id="contact">
  <div class="container">
    <h2 class="section-title fade-in">Let's Connect</h2>
    <p class="section-subtitle fade-in">
      Whether you're a recruiter, a fellow developer, or just someone who wants to chat about cricket
      — I'd love to hear from you.
    </p>
    <div class="contact-links fade-in">
      {links.map((link) => (
        <a href={link.href} target="_blank" rel="noopener" class="contact-card">
          <div class="contact-icon">{link.icon}</div>
          <span class="contact-label">{link.label}</span>
          <span class="contact-value">{link.value}</span>
        </a>
      ))}
    </div>
  </div>
</section>
